# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
.env.*
!.env.example

# Editor/IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Build output
/bin/
/dist/
/tmp/

# NOTE: gen/ is NOT ignored — generated proto code is committed per architecture decision
# NOTE: deploy/envoy/proto.pb is NOT ignored — Envoy descriptor is committed

.opencode
