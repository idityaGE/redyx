@startuml AD01_Registration_OTP
!theme sunlust
skinparam defaultFontSize 13
skinparam ActivityFontSize 13
skinparam ArrowFontSize 12
skinparam padding 5

title AD-01: User Registration + OTP Verification

start

:User submits registration form\n(email, username, password);

partition "**Input Validation**" {
    if (Email format valid?) then (yes)
    else (no)
        :Return error:\n"Invalid email format";
        stop
    endif

    if (Username available?) then (yes)
    else (no)
        :Return error:\n"Username already taken";
        stop
    endif

    if (Email already registered?) then (no)
    else (yes)
        :Return error:\n"Email already in use";
        stop
    endif

    if (Password meets strength rules?) then (yes)
    else (no)
        :Return error:\n"Password too weak";
        stop
    endif
}

partition "**Account Creation**" {
    :Hash password with argon2id\n(memory-hard, GPU-resistant);
    :Insert user record into pg-auth\n(status: INACTIVE);
}

partition "**OTP Flow**" {
    :Generate 6-digit OTP;
    :Store OTP in Redis\n(key: otp:{user_id}, TTL: 5 min);
    :Send OTP to user's email\nvia SMTP provider;
    :Return "Check your email for\nverification code";

    :User submits OTP code;

    if (OTP matches and not expired?) then (yes)
        :Mark OTP as used in Redis;
        :Set user status to ACTIVE\nin pg-auth;
    else (no)
        if (OTP expired?) then (yes)
            :Return error:\n"Code expired, request a new one";
            stop
        else (no)
            :Return error:\n"Incorrect code";
            stop
        endif
    endif
}

partition "**Token Issuance**" {
    :Generate JWT access token\n(15 min TTL);
    :Generate refresh token\n(7 day TTL);
    :Return token pair to client;
}

:User is logged in and active;

stop

@enduml
@startuml AD02_Google_OAuth
!theme sunlust
skinparam defaultFontSize 13
skinparam ActivityFontSize 13
skinparam ArrowFontSize 12
skinparam padding 5

title AD-02: Google OAuth Login / Registration

start

:User clicks "Sign in with Google";

:Frontend redirects to Google\nOAuth consent screen\n(scope: email, profile);

:User authorizes the app on Google;

:Google redirects back to Redyx\nwith authorization code;

partition "**Code Exchange**" {
    :Auth Service sends auth code\nto Google token endpoint;
    :Google returns access token\n+ ID token;
    :Auth Service extracts email\nand provider_user_id from tokens;
}

partition "**Account Resolution**" {
    if (OAuth account exists\nfor this provider_user_id?) then (yes)
        :Look up linked user_id\nfrom oauth_accounts table;
        :Fetch user from pg-auth;
        note right
            Returning user,
            skip registration
        end note
    else (no)
        if (Email already registered\nwith email/password?) then (yes)
            :Link Google OAuth\nto existing account;
            :Store OAuth tokens\nin oauth_accounts;
            note right
                Account linking:
                same email, new provider
            end note
        else (no)
            :Prompt user to\nchoose a username;

            if (Username available?) then (yes)
                :Create new user in pg-auth\n(status: ACTIVE, provider: GOOGLE);
                :Store OAuth tokens\nin oauth_accounts;
                :Create profile in pg-user\n(via gRPC to User Service);
                note right
                    No OTP needed,
                    Google verified the email
                end note
            else (no)
                :Return error:\n"Username taken, pick another";
                stop
            endif
        endif
    endif
}

partition "**Token Issuance**" {
    :Generate JWT access token (15 min);
    :Generate refresh token (7 days);
    :Return token pair to client;
}

:User is logged in;

stop

@enduml
@startuml AD03_Post_Creation
!theme sunlust
skinparam defaultFontSize 13
skinparam ActivityFontSize 13
skinparam ArrowFontSize 12
skinparam padding 5

title AD-03: Post Creation\n(Spam Check → Shard Routing → Kafka Fan-out)

start

:User submits post\n(title, body/URL/media,\ncommunity_id, is_anonymous);

partition "**Auth & Permission Check**" {
    if (User authenticated?) then (yes)
        if (User is member of\nthis community?) then (yes)
            if (User banned from\ncommunity?) then (no)
            else (yes)
                :Return 403:\n"You are banned from\nthis community";
                stop
            endif
        else (no)
            :Return 403:\n"Join the community first";
            stop
        endif
    else (no)
        :Return 401: Unauthorized;
        stop
    endif
}

partition "**Rate Limit Check**" {
    if (Under 5 posts/hour limit?) then (yes)
    else (no)
        :Return 429:\n"Too many posts,\ntry again later";
        stop
    endif
}

partition "**Pre-publish Spam Check**\n(sync call to Spam Detection)" {
    :Send content to P11\nSpam Detection Service;

    fork
        :Check keyword blocklist;
    fork again
        :Check URL reputation\n(if link post);
    fork again
        :Check duplicate content\n(hash comparison);
    fork again
        :Check account age\n(< 24h = blocked);
    end fork

    if (Content passes all checks?) then (yes)
    else (no)
        :Return error with\nrejection reason;
        stop
    endif
}

partition "**Shard Routing**" {
    :Hash community_id through\nconsistent hash ring;
    :Identify target shard\n(pg-post shard N);
    :Open connection to\ntarget shard's DB pool;
}

partition "**Write Post**" {
    :Insert post record into\ntarget shard\n(score=1, upvote_count=1);
    :Auto-apply author's\nown upvote in Redis;
}

partition "**Async Event Fan-out**\n(Kafka: PostCreated)" {
    :Publish PostCreated event\nto Kafka topic;

    fork
        :Search Service\nindexes post in Meilisearch;
    fork again
        :Notification Service\nalerts community followers;
    fork again
        :Spam Detection\nruns async analysis;
    end fork
}

:Return created post\nwith ID, URL, score;

stop

@enduml
@startuml AD04_Vote_Processing
!theme sunlust
skinparam defaultFontSize 13
skinparam ActivityFontSize 13
skinparam ArrowFontSize 12
skinparam padding 5

title AD-04: Vote Processing\n(Sync Redis Write → Async Kafka Fan-out)

start

:User clicks upvote or downvote\n(target_id, target_type, direction);

partition "**Validation**" {
    if (User authenticated?) then (yes)
    else (no)
        :Return 401;
        stop
    endif

    if (Under 60 votes/min?) then (yes)
    else (no)
        :Return 429;
        stop
    endif
}

partition "**Idempotency Check**\n(Redis db0)" {
    :Read current vote state\nfrom Redis\nkey: vote:{type}:{target}:{user};

    if (Existing vote found?) then (yes)
        if (Same direction as\ncurrent vote?) then (yes)
            :No-op, return\ncurrent counts;
            stop
        else (different direction)
            :Record old_direction\nfor delta calculation;
            note right
                Switching up→down = -2
                Switching down→up = +2
            end note
        endif
    else (no vote yet)
        :old_direction = NONE;
    endif
}

partition "**Sync State Update**\n(Redis atomic operations)" {
    :Set new vote direction\nin Redis (db0);

    if (Direction = NONE\n(removing vote)?) then (yes)
        :Delete vote key from Redis;
        if (old was UP?) then (yes)
            :Decrement upvote count;
        else (old was DOWN)
            :Decrement downvote count;
        endif
    else (UP or DOWN)
        if (old_direction = NONE?) then (yes)
            :Increment new direction count;
        else (switching)
            :Decrement old direction count;
            :Increment new direction count;
        endif
    endif

    :Read updated VoteCount\n(upvotes, downvotes, score);
}

partition "**Publish Kafka Event**" {
    :Publish VoteCreated event\n{user_id, target_id, target_type,\nold_direction, new_direction,\nauthor_id, timestamp};
}

:Return updated vote counts\nand user's vote state to client;

partition "**Async Consumers**\n(Kafka: VoteCreated)" {
    fork
        :Post/Comment Service\nupdates score in DB;
    fork again
        :User Service\nadjusts author karma;
    fork again
        :Spam Detection\nchecks for vote manipulation;
    end fork
}

partition "**Durable Persistence**\n(async background)" {
    :Write vote record to\npg-platform (votes schema)\nfor durability;
}

stop

@enduml
@startuml AD05_Comment_Notification
!theme sunlust
skinparam defaultFontSize 13
skinparam ActivityFontSize 13
skinparam ArrowFontSize 12
skinparam padding 5

title AD-05: Comment Creation + Notification Pipeline

start

:User submits comment\n(post_id, parent_id, body);

partition "**Validation & Auth**" {
    if (User authenticated?) then (yes)
    else (no)
        :Return 401;
        stop
    endif

    if (Under 30 comments/hour?) then (yes)
    else (no)
        :Return 429;
        stop
    endif

    :Fetch post info via gRPC\nto Post Service;

    if (Post exists?) then (yes)
        if (Post is locked?) then (no)
        else (yes)
            :Return 403:\n"Post is locked";
            stop
        endif
    else (no)
        :Return 404:\n"Post not found";
        stop
    endif
}

partition "**Spam Check**\n(sync to P11)" {
    :Send comment body to\nSpam Detection Service;

    if (Account age >= 1 hour?) then (yes)
    else (no)
        :Return error:\n"New accounts must wait\n1 hour before commenting";
        stop
    endif

    if (Passes blocklist + dupe check?) then (yes)
    else (no)
        :Return error:\n"Content rejected";
        stop
    endif
}

partition "**Build Materialized Path**" {
    if (parent_id is null?) then (yes)
        :Top-level comment\npath = "{comment_id}"\ndepth = 0;
    else (reply)
        :Fetch parent comment\nfrom ScyllaDB;
        :path = parent.path + "/" + comment_id\ndepth = parent.depth + 1;
    endif
}

partition "**Write to ScyllaDB**" {
    :Insert comment row\npartition_key: post_id\nclustering_key: path;
    note right
        Denormalized fields:
        author_username,
        score=0, reply_count=0
    end note
}

partition "**Post-write Updates**\n(gRPC + Kafka)" {
    fork
        :gRPC to Post Service:\nincrement comment_count;
    fork again
        :Publish CommentCreated\nevent to Kafka;
    end fork
}

partition "**Notification Routing**\n(Kafka consumer in P9)" {
    :Notification Service\nconsumes CommentCreated;

    :Identify recipient\n(post author or parent\ncomment author);

    :Check recipient's\nnotification preferences;

    if (Notifications enabled\nfor replies?) then (yes)
        :Look up recipient in\nRedis connection registry\n(db3: ws:conn:{user_id});

        if (Recipient online?) then (yes)
            :Find pod holding\nthe WebSocket;
            :Push notification\nthrough WebSocket;
            :Increment unread\ncount in Redis;
        else (offline)
            :Store notification\nin pg-platform;
            :Deliver on next\nWebSocket connect;
        endif
    else (muted)
        :Skip notification;
    endif
}

stop

@enduml
@startuml AD06_Account_Deletion
!theme sunlust
skinparam defaultFontSize 13
skinparam ActivityFontSize 13
skinparam ArrowFontSize 12
skinparam padding 5

title AD-06: Account Deletion / Anonymity Purge

start

:User requests account deletion;

partition "**Identity Confirmation**" {
    if (Auth method?) then (email/password)
        :Prompt for password;
        if (Password correct?) then (yes)
        else (no)
            :Return 401:\n"Incorrect password";
            stop
        endif
    else (Google OAuth)
        :Prompt for Google re-auth;
        if (Re-auth successful?) then (yes)
        else (no)
            :Return 401:\n"Could not verify identity";
            stop
        endif
    endif
}

:Mark account as\nPENDING_DELETION in pg-auth;
note right
    Optional: 30-day grace period
    where user can cancel.
    After grace period,
    purge proceeds.
end note

partition "**Auth Data Purge**\n(pg-auth)" {
    :Delete password hash;
    :Delete encrypted email;
    :Delete all OAuth tokens\nfrom oauth_accounts;
    :Delete all OTP records;
    :Invalidate all active\nrefresh tokens (Redis blacklist);
}

partition "**Profile Purge**\n(pg-user via gRPC)" {
    :Delete display name, bio, avatar URL;
    :Reset karma to 0;
    :Delete settings record;
    :Delete avatar file from S3\n(via Media Service);
}

partition "**Content Anonymization**\n(parallel across services)" {
    fork
        partition "Posts (pg-post)" {
            :Set author_id = NULL\non all user's posts;
            :Set author_username = "[deleted]";
            :Clear post body\non all user's posts;
            note right
                Title kept for
                thread context;
                body wiped
            end note
        }
    fork again
        partition "Comments (ScyllaDB)" {
            :Set author_id = NULL\non all user's comments;
            :Set author_username = "[deleted]";
            :Set body = "[deleted]";
            note right
                Tree structure preserved,
                child comments untouched
            end note
        }
    fork again
        partition "Votes (Redis + pg-platform)" {
            :Delete all vote keys\nfrom Redis (db0);
            :Set user_id = NULL\non vote records in pg-platform;
        }
    fork again
        partition "Community Memberships" {
            :Remove user from all\ncommunity memberships;
            :Decrement member counts;
            :Revoke any moderator roles;
        }
    end fork
}

partition "**Notification + Search Cleanup**" {
    fork
        :Delete all notifications\nfor this user (pg-platform);
        :Close WebSocket connection\nif active;
        :Remove from connection\nregistry (Redis db3);
    fork again
        :Update search index:\nreplace author on all\nindexed content (Meilisearch);
    fork again
        :Delete saved posts list;
    end fork
}

partition "**Final Cleanup**" {
    :Release username\n(available after 30 days);
    :Delete user record\nfrom pg-auth;
    :Log deletion event\nin audit log (pg-platform);
}

:Account permanently deleted;

stop

@enduml
